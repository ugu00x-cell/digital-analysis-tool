# Slack Webhook URL（未設定時は通知スキップ）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# データベースパス
DB_PATH=./data/vibration.db

# サンプリング周波数 [Hz]
SAMPLING_RATE=500

# 異常判定しきい値（Zスコア）
ANOMALY_THRESHOLD=3.0

# 各サービスのポート
COLLECTOR_PORT=8001
ANALYZER_PORT=8002
NOTIFIER_PORT=8003

# サービス間通信（Docker環境用）
NOTIFIER_URL=http://notifier:8003
